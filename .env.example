# Supabase
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-public-anon-key
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Gateway
AI_API_KEY=your-ai-api-key
AI_PROVIDER=lovable
AI_GATEWAY_URL=https://ai.gateway.lovable.dev/v1/chat/completions
AI_MODEL=google/gemini-2.5-flash

# OpenRouter (OpenAI-compatible)
# AI_PROVIDER=openai-compatible
# AI_GATEWAY_URL=https://openrouter.ai/api/v1/chat/completions
# AI_API_KEY=sk-or-v1-your-openrouter-key
# AI_MODEL=gpt-4o-mini

# Optional
PORT=8080

# If you use an OpenAI-compatible provider instead of the Lovable gateway, set:
# AI_PROVIDER=openai-compatible
# AI_GATEWAY_URL=https://api.openai.com/v1/chat/completions
